{
  "expo": {
    "name": "san-lucas-mobile",
    "slug": "san-lucas-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/san-lucas-coffee-logo.png",
    "scheme": "sanlucasmobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/san-lucas-coffee-logo.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lyzadev.sanlucasmobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/san-lucas-coffee-logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a1c8a05-bcd5-40ae-a8bf-1c4c20006f08"
      }
    },
    "owner": "lyzadev"
  }
}
